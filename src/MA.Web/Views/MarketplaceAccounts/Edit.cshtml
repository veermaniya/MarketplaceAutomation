@model MarketplaceAccountViewModel
@{ ViewData["Title"] = Model.AccountId == 0 ? "Add Marketplace Account" : "Edit Account"; }

<h2>@ViewData["Title"]</h2>

<div class="alert alert-warning small">
    <strong>Security:</strong> Credentials are encrypted before storage. Filling in passwords below is the
    <em>only</em> place they appear in plaintext &mdash; never in <code>appsettings.json</code>.
</div>

<form asp-action="Save" method="post">
    <input type="hidden" asp-for="AccountId" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="row g-3">
        <div class="col-md-3">
            <label asp-for="Marketplace" class="form-label"></label>
            <select asp-for="Marketplace" class="form-select">
                <option value="Flipkart">Flipkart</option>
                <option value="Amazon">Amazon</option>
                <option value="Meesho">Meesho</option>
            </select>
        </div>
        <div class="col-md-9">
            <label asp-for="DisplayName" class="form-label"></label>
            <input asp-for="DisplayName" class="form-control" placeholder="e.g. 'Main Flipkart Seller'" />
            <span asp-validation-for="DisplayName" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="UserName" class="form-label">Username / Email / Mobile</label>
            <input asp-for="UserName" class="form-control" autocomplete="off" />
            <span asp-validation-for="UserName" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="Password" class="form-label"></label>
            <input asp-for="Password" type="password" class="form-control" autocomplete="new-password" />
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>

        <div class="col-md-4">
            <label asp-for="SellerId" class="form-label">Seller Id (optional)</label>
            <input asp-for="SellerId" class="form-control" placeholder="e.g. Amazon Merchant Token" />
        </div>
        <div class="col-md-4">
            <label asp-for="ApiKey" class="form-label">API Key (optional)</label>
            <input asp-for="ApiKey" class="form-control" autocomplete="off" placeholder="LWA refresh token / etc." />
        </div>
        <div class="col-md-4">
            <label asp-for="ApiSecret" class="form-label">API Secret (optional)</label>
            <input asp-for="ApiSecret" type="password" class="form-control" autocomplete="new-password" />
        </div>
    </div>

    <div class="mt-4">
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Index" class="btn btn-link">Cancel</a>
    </div>
</form>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
